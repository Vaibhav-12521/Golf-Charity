# ---------- Supabase ----------
# Create a NEW project at https://supabase.com -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# ---------- Stripe ----------
# Create a NEW Stripe account at https://stripe.com -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring Price IDs from your Stripe dashboard (Products -> Add product)
# Both should belong to ONE product ("Golf Charity Subscription")
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_YEARLY=price_...

# Subscription amounts in CENTS (used to compute prize pool + charity share when webhook fires)
SUBSCRIPTION_PRICE_MONTHLY_CENTS=1500
SUBSCRIPTION_PRICE_YEARLY_CENTS=14400

# ---------- App ----------
# Public URL used for Stripe redirects + email links. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated list of admin emails. Users matching one of these are auto-promoted on signup.
ADMIN_EMAILS=admin@example.com

# ---------- Email (Resend) ----------
# Optional but recommended. Create at https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM="Birdie & Cause <no-reply@yourdomain.com>"
